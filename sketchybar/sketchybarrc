PLUGIN_DIR="$CONFIG_DIR/plugins"

bar_options=(
  position=top
  height=20
  blur_radius=40
  color=0x40000000
  padding_left=13
  padding_right=10
)

font='MesloLGS Nerd Font'
default=(
  icon.font="$font:Bold:13.5"
  label.font="$font:Bold:12.5"
  icon.color=0xffffffff
  label.color=0xffffffff
  label.shadow.drawing=on
  label.shadow.distance=1
  padding_left=4
  padding_right=4
  icon.padding_left=4
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=4
  background.color=0x2affffff
  background.padding_left=2
  background.corner_radius=3
  background.height=15
  background.drawing=off
)

sketchybar --bar "${bar_options[@]}" \
           --default "${default[@]}"


events=(
  --add event window_focus
  --add event title_change
)

plugins=(
  --add item title center
  --set title
        script="$PLUGIN_DIR/window_title.sh"
  --subscribe title
              window_focus
              front_app_switched
              title_change

  --add item clock right
  --set clock update_freq=10
              icon.drawing=off
              script="$PLUGIN_DIR/clock.sh"

  --add item calendar right
  --set calendar update_freq=10
                 icon.drawing=off
                 script="$PLUGIN_DIR/calendar.sh"

  --add item battery right
  --set battery update_freq=10
                script="$PLUGIN_DIR/battery.sh"
)

spaces_options=()
for space in {1..6}; do
  spaces_options+=(
    --add space space."$space" left
    --set space."$space"
          space="$space"
          label="$space"
          icon.drawing=off
          script="$PLUGIN_DIR/space.sh"
          click_script="yabai -m space --focus $sid"
  )
done

sketchybar -m "${events[@]}" \
              "${plugins[@]}" \
              "${spaces_options[@]}"

# Force all scripts to run the first time
sketchybar --update
